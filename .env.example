# Server
PORT=8080
NODE_ENV=development
FRONTEND_URL=https://your-domain.com

# MongoDB (required)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Auth (Clerk) — required
CLERK_SECRET_KEY=sk_...
CLERK_WEBHOOK_SECRET=whsec_...

# OpenClaw (agent containers)
OPENCLAW_WORKSPACE_DIR=
OPENCLAW_BASE_PORT=18789
OPENCLAW_IMAGE_TAG=openclaw-secure:latest
# Fork URL for Docker build (clone separately, publish your fork)
OPENCLAW_FORK_URL=https://github.com/YOUR_ORG/openclaw-saas-fork.git

# Platform AI (for builder, support, analytics)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Web Search (builder)
TAVILY_API_KEY=
BRAVE_API_KEY=

# Security — required in production
ENCRYPTION_KEY=           # 32-byte hex: openssl rand -hex 32
ADMIN_API_KEY=            # 32+ chars for admin dashboard

# Stripe (billing)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_PORTAL_CONFIG_ID=
STRIPE_BASIS_PRODUCT_ID=

# Backend URL for agent containers (Superchat, Knowledge, MCP plugins)
# Docker Desktop: http://host.docker.internal:8080
# Linux: http://172.17.0.1:8080
PLATFORM_BACKEND_URL=
# Legacy alias (optional): HAVOC_BACKEND_URL=

# Optional
SMITHERY_API_KEY=         # MCP integrations (Smithery Connect)
SUPERCHAT_WEBHOOK_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=       # e.g. YourApp <invites@your-domain.com>
SUPPORT_EMAIL=           # Contact for Terms/Privacy (e.g. support@your-domain.com)
LLAMA_PARSE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=
GATEWAY_ALLOWLIST=
NETWORK_EGRESS_ALLOWLIST=
SENTRY_DSN=
